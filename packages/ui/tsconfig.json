{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "paths": {
      "@kilo/ui/*": ["./src/lib/components/ui/*/index.ts"],
      "@kilo/ui/utils": ["./src/lib/utils.ts"],
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "src/**/*.ts"
  ]
}
