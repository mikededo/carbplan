{
  "name": "@carbplan/db",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seed": "./src/seed/index.ts"
  },
  "scripts": {
    "build": "echo 'No build step for @carbplan/db'",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/migrate.ts",
    "db:migrate:kit": "drizzle-kit migrate",
    "db:seed": "bun src/seed/index.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "drizzle-orm": "0.44.7",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "@carbplan/eslint": "workspace:*",
    "@types/bun": "1.3.10",
    "drizzle-kit": "0.31.10",
    "typescript": "5.9.3"
  }
}
