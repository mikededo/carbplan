{
  "name": "@kilo/db",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seed": "./src/seed/index.ts"
  },
  "scripts": {
    "build": "echo 'No build step for @kilo/db'",
    "check": "tsc --noEmit",
    "typecheck": "bun run check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/seed/index.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@kilo/domain": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@kilo/eslint": "workspace:*",
    "@types/bun": "1.3.14",
    "drizzle-kit": "0.31.10",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
