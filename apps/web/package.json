{
  "name": "@kilo/web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "portless": {
    "appPort": 5173,
    "name": "app.kilo",
    "script": "dev:app"
  },
  "scripts": {
    "dev": "portless",
    "dev:app": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "gen:i18n": "echo 'No i18n generation configured'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@elysiajs/eden": "1.4.9",
    "@kilo/api": "workspace:*",
    "@kilo/auth": "workspace:*",
    "@kilo/contracts": "workspace:*",
    "@kilo/domain": "workspace:*",
    "@kilo/ui": "workspace:*",
    "@kilo/utils": "workspace:*",
    "@lucide/svelte": "1.17.0",
    "@tanstack/svelte-query": "6.1.34",
    "@tanstack/svelte-query-devtools": "6.1.34",
    "clsx": "2.1.1",
    "neverthrow": "catalog:",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@kilo/eslint": "workspace:*",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.63.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "elysia": "1.4.28",
    "eslint": "catalog:",
    "globals": "17.6.0",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "catalog:",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
