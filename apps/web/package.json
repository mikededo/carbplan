{
  "name": "@carbplan/web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "portless": {
    "appPort": 5173,
    "name": "app.carbplan",
    "script": "dev:app"
  },
  "scripts": {
    "dev": "portless",
    "dev:app": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "gen:i18n": "echo 'No i18n generation configured'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@carbplan/contracts": "workspace:*",
    "@carbplan/domain": "workspace:*",
    "@carbplan/utils": "workspace:*",
    "@lucide/svelte": "1.14.0",
    "@tanstack/svelte-query": "6.1.29",
    "@tanstack/svelte-query-devtools": "6.1.29",
    "clsx": "2.1.1",
    "neverthrow": "catalog:",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@carbplan/eslint": "workspace:*",
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/geist-mono": "5.2.7",
    "@internationalized/date": "3.12.1",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "bits-ui": "2.18.1",
    "eslint": "catalog:",
    "globals": "17.6.0",
    "shadcn-svelte": "1.2.7",
    "svelte": "5.55.5",
    "svelte-check": "4.4.8",
    "tailwindcss": "4.3.0",
    "typescript": "catalog:",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  }
}
