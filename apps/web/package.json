{
  "name": "@carbplan/web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "gen:i18n": "echo 'No i18n generation configured'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "bun run check",
    "db:types": "bun scripts/db-types.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@lucide/svelte": "^0.577.0",
    "@supabase/ssr": "0.10.0",
    "@supabase/supabase-js": "2.99.2",
    "@tanstack/svelte-query": "6.1.1",
    "@tanstack/svelte-query-devtools": "6.0.4",
    "clsx": "2.1.1",
    "neverthrow": "8.2.0",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@carbplan/eslint": "workspace:*",
    "@internationalized/date": "3.12.0",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.55.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/bun": "1.3.11",
    "bits-ui": "2.16.3",
    "eslint": "catalog:",
    "globals": "17.4.0",
    "supabase": "2.81.3",
    "svelte": "5.54.0",
    "svelte-check": "4.4.6",
    "tailwindcss": "4.2.2",
    "typescript": "catalog:",
    "vite": "8.0.1",
    "vitest": "4.1.2"
  }
}
