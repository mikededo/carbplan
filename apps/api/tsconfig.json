{
  "compilerOptions": {
    "target": "esnext",
    "baseUrl": ".",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "$bootstrap/*": [
        "./src/bootstrap/*"
      ],
      "$modules": [
        "./src/modules"
      ],
      "$modules/*": [
        "./src/modules/*"
      ],
      "$utils/*": [
        "./src/utils/*"
      ],
      "$test/*": [
        "./src/test/*"
      ]
    },
    "types": [
      "bun-types",
      "vitest/globals"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
