{
  "compilerOptions": {
    "target": "ES2021",
    "baseUrl": ".",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "$bootstrap/*": ["./src/bootstrap/*"],
      "$modules": ["./src/modules"],
      "$modules/*": ["./src/modules/*"]
    },
    "types": ["bun-types"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
