{
  "name": "@kilo/static",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "portless": {
    "appPort": 5174,
    "name": "kilo.localhost",
    "script": "dev:app"
  },
  "scripts": {
    "dev": "portless",
    "dev:app": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "bun run check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@kilo/ui": "workspace:*",
    "@lucide/svelte": "1.17.0"
  },
  "devDependencies": {
    "@kilo/eslint": "workspace:*",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.63.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "eslint": "catalog:",
    "globals": "17.6.0",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "catalog:",
    "vite": "8.0.16"
  }
}
