{
  "name": "@carbplan/root",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "turbo run build",
    "ci": "bun run typecheck && bun run lint && bun run test && bun run build",
    "dev": "turbo run dev",
    "dev:raw": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "preview": "turbo run preview",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "portless": "0.14.0",
    "turbo": "2.9.16"
  },
  "overrides": {
    "cookie": "1.1.1",
    "esbuild": "0.27.4"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "drizzle-orm": "0.45.2",
      "eslint": "10.4.1",
      "neverthrow": "8.2.0",
      "typescript": "6.0.3",
      "vitest": "4.1.8",
      "zod": "4.4.3"
    }
  }
