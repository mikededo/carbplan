{
  "name": "@carbplan/root",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "turbo run build",
    "ci": "bun run typecheck && bun run lint && bun run test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "preview": "turbo run preview",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "2.8.19",
    "eslint": "catalog:"
  },
  "overrides": {
    "brace-expansion": "1.1.13",
    "cookie": "1.1.1",
    "esbuild": "0.27.4",
    "kysely": "0.28.15",
    "picomatch": "4.0.4",
    "yaml": "1.10.3"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "eslint": "10.0.3",
      "typescript": "5.9.3",
      "vitest": "4.1.2",
      "zod": "4.3.6"
    }
  }
}
